# Environment variables / secrets
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
*.egg-info/

# Node
node_modules/
.next/
out/

# ChromaDB (too large for git)
chromadb_store/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
.vscode/
*.swp
*.swo

# Misc
*.log
*.sqlite3
.Rhistory

# Runtime caches (do not commit)
data/news_runtime_cache.json
data/competitor_dynamic_cache.json
data/preset_questions_cache.json

# Hyperscaler Gemini cache (runtime, regenerated on refresh)
data/hyperscaler/big5_capex_view_model.json
data/hyperscaler/big5_capex_api_raw.json

# News runtime cache
data/news_cache/

# Databases (runtime, not for version control)
data/*.db
data/*.db-shm
data/*.db-wal
data/news/*.db
data/news/*.db-shm
data/news/*.db-wal

# Chat session data (user-specific runtime data)
data/chat_history.json
data/chat_messages/

# Analyst intel DB (runtime)
data/analyst_intel.db
